# コピーして .env.local を作る。本番は Secret Manager（直書き禁止・security.md）。

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # サーバー専用（lib/supabase/admin.ts のみ）

# --- Cloudflare R2（原本7年保存） ---
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kojima-noen

# --- cron 認証（Cloud Scheduler） ---
CRON_SECRET=

# --- Google Drive 取り込み（Phase B） ---
DRIVE_FOLDER_ID=
# DRIVE_POLL_SINCE=                 # 初回は空（全件）。以降はISO時刻
# FAX_FILENAME_PATTERN=            # 既定: (?<fax>\d{6,11})[_-](?<date>\d{8})

# --- IMAP メール取り込み（Phase B） ---
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
# ORDER_KEYWORDS=注文,発注,ご注文,オーダー

# --- Gemini（Phase B） ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- 通知（Phase G・ON/OFF切替可） ---
DISCORD_WEBHOOK_URL=
LINE_WORKS_WEBHOOK_URL=
# NOTIFY_DISCORD=off
# NOTIFY_LINE_WORKS=off
